#!/usr/bin/env bash

function main() {
    local command="${1:-}"

    case "$command" in
        info)
            # Get current scene name - filter out the "Executing:" line and extract the scene name
            obs-cmd scene current | grep '^Current scene:' | sed 's/Current scene: //'
            ;;
        switch)
            # Get list of scenes and extract just the scene names
            local scenes
            scenes=$(obs-cmd scene list | grep '^  - ' | sed 's/^  - //')

            # Use rofi in dmenu mode to let user select a scene
            local selected
            selected=$(echo "$scenes" | rofi -dmenu -p "Switch to scene:")

            # Switch to the selected scene if one was chosen
            if [[ -n "$selected" ]]; then
                obs-cmd scene switch "$selected"
            fi
            ;;
        *)
            echo "Usage: n-obs <command>"
            echo "Commands:"
            echo "  info    - Show current scene name"
            echo "  switch  - Switch scenes using rofi"
            ;;
    esac
}

main "$@"